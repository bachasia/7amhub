# 7AM Hub server config
PORT=8787

# Anthropic API — bắt buộc để AI phân loại/tóm tắt/digest hoạt động
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Model: Haiku xử lý từng bài (rẻ), Sonnet cho bản tin tổng hợp hằng ngày
MODEL_FAST=claude-haiku-4-5-20251001
MODEL_SMART=claude-sonnet-4-6

# Lịch chạy (cron). Mặc định: ingest mỗi 15 phút, digest 07:00 hằng ngày
INGEST_CRON=*/15 * * * *
AI_WORKER_CRON=*/2 * * * *
DIGEST_CRON=0 7 * * *
TZ=Asia/Saigon

# SQLite
DB_PATH=./data/7amhub.db
